generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AccountRole {
  ADMIN
  FARMER
  TRANSPORTER
  WAREHOUSE
  STORE
  INSPECTOR

  @@map("account_role")
}

enum AccountStatus {
  ACTIVE
  LOCKED

  @@map("account_status")
}

enum PartnerType {
  FARM
  TRANSPORT_COMPANY
  STORE

  @@map("partner_type")
}

enum CooperationStatus {
  PENDING
  APPROVED
  TERMINATED

  @@map("cooperation_status")
}

enum BatchStatus {
  CREATED
  AT_WAREHOUSE
  IN_TRANSIT
  DELIVERED
  INCIDENT_REPORTED
  CANCELLED

  @@map("batch_status")
}

enum CertificateType {
  VietGAP
  GlobalGAP
  HACCP
  OTHER

  @@map("certificate_type")
}

enum CertificateStatus {
  ACTIVE
  EXPIRED
  REVOKED

  @@map("certificate_status")
}

enum TransportStatus {
  PENDING_PICKUP
  IN_TRANSIT
  ARRIVED_WAREHOUSE
  DELIVERED
  INCIDENT_REPORTED

  @@map("transport_status")
}

enum IncidentType {
  DAMAGED
  MISSING
  QUALITY_ISSUE
  OTHER

  @@map("incident_type")
}

enum QrScanResult {
  SUCCESS
  INACTIVE
  NOT_FOUND

  @@map("qr_scan_result")
}

enum QrCodeStatus {
  ACTIVE
  INACTIVE

  @@map("qr_code_status")
}

model Account {
  accountId     Int             @id @default(autoincrement()) @map("account_id")
  partnerId     Int?            @map("partner_id")
  username      String          @unique @db.VarChar(50)
  passwordHash  String          @map("password_hash") @db.VarChar(255)
  fullName      String          @map("full_name") @db.VarChar(100)
  email         String          @unique @db.VarChar(100)
  phone         String?         @db.VarChar(20)
  role          AccountRole
  status        AccountStatus   @default(ACTIVE)
  createdAt     DateTime?       @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt     DateTime?       @updatedAt @map("updated_at") @db.Timestamp(3)
  partner       PartnerProfile? @relation("AccountPartner", fields: [partnerId], references: [partnerId])
  profile       PartnerProfile? @relation("PartnerAccount")
  createdBatch  Batch[]         @relation("BatchCreatedBy")
  createdTransports Transport[] @relation("TransportCreatedBy")
  deliveries    Transport[]     @relation("DeliveryConfirmedBy")
  reportedItems Incident[]      @relation("IncidentReportedBy")
  auditLogs     AuditLog[]      @relation("AuditActor")
  statusChanges BatchStatusHistory[] @relation("BatchStatusChangedBy")

  @@index([partnerId])
  @@map("account")
}

model PartnerProfile {
  partnerId          Int                @id @default(autoincrement()) @map("partner_id")
  accountId          Int?               @unique @map("account_id")
  partnerType        PartnerType        @map("partner_type")
  partnerName        String             @map("partner_name") @db.VarChar(200)
  taxCode            String?            @map("tax_code") @db.VarChar(20)
  address            String?            @db.VarChar(500)
  contactPerson      String?            @map("contact_person") @db.VarChar(100)
  cooperationStatus  CooperationStatus? @default(APPROVED) @map("cooperation_status")
  createdAt          DateTime?          @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt          DateTime?          @updatedAt @map("updated_at") @db.Timestamp(3)
  account            Account?           @relation("PartnerAccount", fields: [accountId], references: [accountId])
  accounts           Account[]          @relation("AccountPartner")
  farmBatches        Batch[]            @relation("BatchFarmPartner")
  locatedBatches     Batch[]            @relation("BatchCurrentLocation")
  certificates       Certificate[]      @relation("CertificateIssuer")
  shippedTransports  Transport[]        @relation("TransportShipper")
  receivedTransports Transport[]        @relation("TransportReceiver")
  farmTransports     Transport[]        @relation("TransportFarm")
  storeTransports    Transport[]        @relation("TransportStore")
  transporterTransports Transport[]     @relation("TransportTransporter")

  @@map("partner_profile")
}

model Batch {
  batchId        Int             @id @default(autoincrement()) @map("batch_id")
  batchCode      String          @unique @map("batch_code") @db.VarChar(50)
  farmPartnerId  Int?            @map("farm_partner_id")
  farmingMethods String?         @map("farming_methods") @db.VarChar(200)
  productName    String          @map("product_name") @db.VarChar(200)
  productType    String?         @map("product_type") @db.VarChar(100)
  quantity       Decimal         @db.Decimal(12, 2)
  currentQuantity Decimal?       @map("current_quantity") @db.Decimal(12, 2)
  unit           String?         @default("kg") @db.VarChar(20)
  harvestDate    DateTime?       @map("harvest_date") @db.Date
  packagedDate   DateTime?       @map("packaged_date") @db.Date
  expiryDate     DateTime?       @map("expiry_date") @db.Date
  currentLocationPartnerId Int?   @map("current_location_partner_id")
  status         BatchStatus?    @default(CREATED)
  createdBy      Int?            @map("created_by")
  createdAt      DateTime?       @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt      DateTime?       @updatedAt @map("updated_at") @db.Timestamp(3)
  farmPartner    PartnerProfile? @relation("BatchFarmPartner", fields: [farmPartnerId], references: [partnerId])
  currentLocation PartnerProfile? @relation("BatchCurrentLocation", fields: [currentLocationPartnerId], references: [partnerId])
  creator        Account?        @relation("BatchCreatedBy", fields: [createdBy], references: [accountId])
  certificates   BatchCert[]
  transport      Transport?
  incidents      Incident[]
  qrCode         QrCode?
  scanLogs       QrScanLog[]
  statusHistory  BatchStatusHistory[]

  @@index([farmPartnerId])
  @@index([currentLocationPartnerId])
  @@index([createdBy])
  @@map("batch")
}

model Certificate {
  certificateId   Int                @id @default(autoincrement()) @map("certificate_id")
  issuerPartnerId Int?               @map("issuer_partner_id")
  certType        CertificateType    @map("cert_type")
  issuedBy        String             @map("issued_by") @db.VarChar(200)
  issuedDate      DateTime           @map("issued_date") @db.Date
  expiryDate      DateTime           @map("expiry_date") @db.Date
  filePath        String?            @map("file_path") @db.VarChar(500)
  status          CertificateStatus? @default(ACTIVE)
  createdAt       DateTime?          @default(now()) @map("created_at") @db.Timestamp(3)
  issuer          PartnerProfile?    @relation("CertificateIssuer", fields: [issuerPartnerId], references: [partnerId])
  batches         BatchCert[]

  @@index([issuerPartnerId])
  @@map("certificate")
}

model BatchCert {
  batchId       Int         @map("batch_id")
  certificateId Int         @map("certificate_id")
  linkedAt      DateTime?   @default(now()) @map("linked_at") @db.Timestamp(3)
  batch         Batch       @relation(fields: [batchId], references: [batchId])
  certificate   Certificate @relation(fields: [certificateId], references: [certificateId])

  @@id([batchId, certificateId])
  @@map("batch_cert")
}

model Transport {
  transportId         Int                   @id @default(autoincrement()) @map("transport_id")
  batchId             Int?                  @unique @map("batch_id")
  shipperPartnerId    Int?                  @map("shipper_partner_id")
  receiverPartnerId   Int?                  @map("receiver_partner_id")
  farmPartnerId       Int?                  @map("farm_partner_id")
  storePartnerId      Int?                  @map("store_partner_id")
  transporterPartnerId Int?                 @map("transporter_partner_id")
  driverName          String?               @map("driver_name") @db.VarChar(100)
  licensePlate        String?               @map("license_plate") @db.VarChar(20)
  transportStatus     TransportStatus?      @default(PENDING_PICKUP) @map("transport_status")
  actualDeparture     DateTime?             @map("actual_departure") @db.Timestamp(3)
  expectedArrival     DateTime?             @map("expected_arrival_time") @db.Timestamp(3)
  actualArrival       DateTime?             @map("actual_arrival") @db.Timestamp(3)
  createdBy           Int?                  @map("created_by")
  deliveryConfirmedBy Int?                  @map("delivery_confirmed_by")
  createdAt           DateTime?             @default(now()) @map("created_at") @db.Timestamp(3)
  updatedAt           DateTime?             @updatedAt @map("updated_at") @db.Timestamp(3)
  reasonCancel        String?               @map("reason_cancel") @db.VarChar(200)
  batch               Batch?                @relation(fields: [batchId], references: [batchId])
  shipperPartner      PartnerProfile?       @relation("TransportShipper", fields: [shipperPartnerId], references: [partnerId])
  receiverPartner     PartnerProfile?       @relation("TransportReceiver", fields: [receiverPartnerId], references: [partnerId])
  farmPartner         PartnerProfile?       @relation("TransportFarm", fields: [farmPartnerId], references: [partnerId])
  storePartner        PartnerProfile?       @relation("TransportStore", fields: [storePartnerId], references: [partnerId])
  transporterPartner  PartnerProfile?       @relation("TransportTransporter", fields: [transporterPartnerId], references: [partnerId])
  creator             Account?              @relation("TransportCreatedBy", fields: [createdBy], references: [accountId])
  deliveryConfirmer   Account?              @relation("DeliveryConfirmedBy", fields: [deliveryConfirmedBy], references: [accountId])
  checkpoints         TransportCheckpoint[]
  incidents           Incident[]

  @@index([shipperPartnerId])
  @@index([receiverPartnerId])
  @@index([farmPartnerId])
  @@index([storePartnerId])
  @@index([transporterPartnerId])
  @@index([createdBy])
  @@index([deliveryConfirmedBy])
  @@map("transport")
}

model TransportCheckpoint {
  checkpointId       Int        @id @default(autoincrement()) @map("checkpoint_id")
  transportId        Int?       @map("transport_id")
  sequence           Int
  locationName       String?    @map("location_name") @db.VarChar(200)
  latitude           Decimal?   @db.Decimal(10, 7)
  longitude          Decimal?   @db.Decimal(10, 7)
  temperature        Decimal?   @db.Decimal(4, 1)
  statusAtCheckpoint String?    @map("status_at_checkpoint") @db.VarChar(50)
  note               String?    @db.VarChar(500)
  reportedAt         DateTime?  @default(now()) @map("reported_at") @db.Timestamp(3)
  transport          Transport? @relation(fields: [transportId], references: [transportId])

  @@index([transportId])
  @@map("transport_checkpoint")
}

model Incident {
  incidentId       Int          @id @default(autoincrement()) @map("incident_id")
  transportId      Int?         @map("transport_id")
  batchId          Int?         @map("batch_id")
  reportedBy       Int?         @map("reported_by")
  incidentType     IncidentType @map("incident_type")
  description      String?      @db.VarChar(1000)
  quantityAffected Decimal?     @map("quantity_affected") @db.Decimal(12, 2)
  photoPath        String?      @map("photo_path") @db.VarChar(500)
  createdAt        DateTime?    @default(now()) @map("created_at") @db.Timestamp(3)
  transport        Transport?   @relation(fields: [transportId], references: [transportId])
  batch            Batch?       @relation(fields: [batchId], references: [batchId])
  reporter         Account?     @relation("IncidentReportedBy", fields: [reportedBy], references: [accountId])

  @@index([transportId])
  @@index([batchId])
  @@index([reportedBy])
  @@map("incident")
}

model QrCode {
  qrId        Int           @id @default(autoincrement()) @map("qr_id")
  batchId     Int?          @unique @map("batch_id")
  traceToken  String        @unique @map("trace_token") @db.VarChar(80)
  qrUrl       String?       @map("qr_url") @db.VarChar(500)
  qrImagePath String        @map("qr_image_path") @db.VarChar(500)
  status      QrCodeStatus? @default(ACTIVE)
  createdAt   DateTime?     @default(now()) @map("created_at") @db.Timestamp(3)
  batch       Batch?        @relation(fields: [batchId], references: [batchId])
  scanLogs    QrScanLog[]

  @@map("qr_code")
}

model AuditLog {
  auditId    BigInt   @id @default(autoincrement()) @map("audit_id")
  actorId    Int?     @map("actor_id")
  action     String   @db.VarChar(100)
  objectType String   @map("object_type") @db.VarChar(100)
  objectId   String   @map("object_id") @db.VarChar(100)
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.VarChar(500)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  actor      Account? @relation("AuditActor", fields: [actorId], references: [accountId])

  @@index([actorId])
  @@index([objectType, objectId])
  @@index([createdAt])
  @@map("audit_log")
}

model BatchStatusHistory {
  historyId    BigInt      @id @default(autoincrement()) @map("history_id")
  batchId      Int         @map("batch_id")
  status       BatchStatus
  locationName String?     @map("location_name") @db.VarChar(200)
  note         String?     @db.VarChar(500)
  changedBy    Int?        @map("changed_by")
  changedAt    DateTime    @default(now()) @map("changed_at") @db.Timestamp(3)
  batch        Batch       @relation(fields: [batchId], references: [batchId])
  changer      Account?    @relation("BatchStatusChangedBy", fields: [changedBy], references: [accountId])

  @@index([batchId])
  @@index([changedBy])
  @@index([changedAt])
  @@map("batch_status_history")
}

model QrScanLog {
  scanId        BigInt        @id @default(autoincrement()) @map("scan_id")
  qrId          Int           @map("qr_id")
  batchId       Int           @map("batch_id")
  scanTimestamp DateTime      @default(now()) @map("scan_timestamp") @db.Timestamp(3)
  userAgent     String?       @map("user_agent") @db.VarChar(500)
  ipAddress     String?       @map("ip_address") @db.VarChar(45)
  referer       String?       @db.VarChar(500)
  scanResult    QrScanResult? @default(SUCCESS) @map("scan_result")
  qrCode        QrCode        @relation(fields: [qrId], references: [qrId])
  batch         Batch         @relation(fields: [batchId], references: [batchId])

  @@index([qrId])
  @@index([batchId])
  @@map("qr_scan_log")
}
